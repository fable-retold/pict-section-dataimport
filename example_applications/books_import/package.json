{
	"name": "books_import",
	"version": "0.0.1",
	"description": "Demo: import a books CSV into the quackage sqlite bookstore harness via pict-section-dataimport.",
	"main": "source/Pict-Application-BooksImport.js",
	"scripts": {
		"start": "node source/Pict-Application-BooksImport.js",
		"build": "npx quack build && npx quack copy"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.373",
		"pict-application": "^1.0.34",
		"pict-view": "^1.0.68"
	},
	"devDependencies": {
		"quackage": "^1.3.0"
	},
	"copyFilesSettings": { "whenFileExists": "overwrite" },
	"copyFiles": [
		{ "from": "./html/*", "to": "./dist/" },
		{ "from": "./css/**", "to": "./dist/css/" },
		{ "from": "./node_modules/pict/dist/*", "to": "./dist/js/" }
	]
}
